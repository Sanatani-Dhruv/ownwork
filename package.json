{
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "scripts": {
    "dev": "npx concurrently --names=\"OwnWork,Tailwind,Transpiler\" --prefix-colors=\"blue,red,green\" \"php -S localhost:8000 --docroot='public/'\" \"npx @tailwindcss/cli -i ./resources/css/tailwind.css -o ./public/build/output.css --watch\" \"./worker transpile\"",
    "build": "npx concurrently --names=\"Tailwind\" --prefix-colors=\"red\" \"npx @tailwindcss/cli -i ./resources/css/tailwind.css -o ./public/build/output.css --minify\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
